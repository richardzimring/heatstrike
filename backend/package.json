{
  "name": "heatstrike-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "serverless offline",
    "deploy": "serverless deploy --stage dev",
    "lint": "npx eslint . && tsc --noEmit",
    "lint:fix": "npx eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "npx prettier --write \"lambdas/**/*.{ts,json}\" \"src/**/*.{ts,json}\"",
    "check": "npx prettier --check \"lambdas/**/*.{ts,json}\" \"src/**/*.{ts,json}\"",
    "generate:openapi": "tsx --env-file=.env scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1010.0",
    "@aws-sdk/client-s3": "^3.1010.0",
    "@aws-sdk/client-ses": "^3.1010.0",
    "@aws-sdk/lib-dynamodb": "^3.1010.0",
    "@hono/zod-openapi": "^0.19.10",
    "hono": "^4.12.8",
    "serverless-api-gateway-throttling": "^2.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^24.12.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "serverless": "^4.33.0",
    "serverless-offline": "^14.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
